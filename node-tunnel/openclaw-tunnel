#!/usr/bin/env bash
#
# OpenClaw Node Tunnel Manager
# 管理 SSH 隧道和 OpenClaw 节点的启动、停止和自动化
#

set -euo pipefail

# 配置文件路径
CONFIG_DIR="${HOME}/.openclaw/tools/tunnel"
CONFIG_FILE="${CONFIG_DIR}/config.json"
PID_DIR="${CONFIG_DIR}/pids"
LOG_DIR="${CONFIG_DIR}/logs"

# 默认配置 - 请根据你的环境修改这些占位符
# 或者运行 `openclaw-tunnel config` 进行交互式配置
DEFAULT_GATEWAY_HOST="YOUR_GATEWAY_HOST"      # 例如: 1.2.3.4 或 gateway.example.com
DEFAULT_GATEWAY_PORT="18789"                   # Gateway 监听端口
DEFAULT_LOCAL_PORT="18790"                     # 本地 SSH 隧道端口
DEFAULT_NODE_NAME="YOUR_NODE_NAME"             # 例如: MyMacBook
DEFAULT_GATEWAY_TOKEN="YOUR_GATEWAY_TOKEN"     # Gateway 认证令牌

# 颜色输出
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# 日志函数
log_info() {
    echo -e "${BLUE}ℹ${NC} $1"
}

log_success() {
    echo -e "${GREEN}✓${NC} $1"
}

log_warning() {
    echo -e "${YELLOW}⚠${NC} $1"
}

log_error() {
    echo -e "${RED}✗${NC} $1"
}

# 初始化目录
init_dirs() {
    mkdir -p "${CONFIG_DIR}" "${PID_DIR}" "${LOG_DIR}"
}

# 加载配置
load_config() {
    if [[ -f "${CONFIG_FILE}" ]]; then
        GATEWAY_HOST=$(jq -r '.gateway_host // empty' "${CONFIG_FILE}" || echo "")
        GATEWAY_PORT=$(jq -r '.gateway_port // empty' "${CONFIG_FILE}" || echo "")
        LOCAL_PORT=$(jq -r '.local_port // empty' "${CONFIG_FILE}" || echo "")
        NODE_NAME=$(jq -r '.node_name // empty' "${CONFIG_FILE}" || echo "")
        GATEWAY_TOKEN=$(jq -r '.gateway_token // empty' "${CONFIG_FILE}" || echo "")
        SSH_USER=$(jq -r '.ssh_user // empty' "${CONFIG_FILE}" || echo "YOUR_SSH_USER")
    else
        GATEWAY_HOST="${DEFAULT_GATEWAY_HOST}"
        GATEWAY_PORT="${DEFAULT_GATEWAY_PORT}"
        LOCAL_PORT="${DEFAULT_LOCAL_PORT}"
        NODE_NAME="${DEFAULT_NODE_NAME}"
        GATEWAY_TOKEN="${DEFAULT_GATEWAY_TOKEN}"
        SSH_USER="YOUR_SSH_USER"
    fi
}

# 保存配置
save_config() {
    cat > "${CONFIG_FILE}" <<EOF
{
  "gateway_host": "${GATEWAY_HOST}",
  "gateway_port": "${GATEWAY_PORT}",
  "local_port": "${LOCAL_PORT}",
  "node_name": "${NODE_NAME}",
  "gateway_token": "${GATEWAY_TOKEN}",
  "ssh_user": "${SSH_USER}"
}
EOF
    log_success "配置已保存到 ${CONFIG_FILE}"
}

# 交互式配置
interactive_config() {
    log_info "OpenClaw 节点隧道配置向导"
    echo ""
    echo "提示: 默认值显示在方括号中，直接按回车使用默认值"
    echo ""
    
    read -p "Gateway 主机地址 [${GATEWAY_HOST}]: " input
    GATEWAY_HOST="${input:-${GATEWAY_HOST}}"
    
    read -p "Gateway 端口 [${GATEWAY_PORT}]: " input
    GATEWAY_PORT="${input:-${GATEWAY_PORT}}"
    
    read -p "本地隧道端口 [${LOCAL_PORT}]: " input
    LOCAL_PORT="${input:-${LOCAL_PORT}}"
    
    read -p "节点名称 [${NODE_NAME}]: " input
    NODE_NAME="${input:-${NODE_NAME}}"
    
    read -p "SSH 用户名 [${SSH_USER}]: " input
    SSH_USER="${input:-${SSH_USER}}"
    
    read -sp "Gateway Token: " input
    echo ""
    if [[ -n "${input}" ]]; then
        GATEWAY_TOKEN="${input}"
    fi
    
    echo ""
    save_config
}

# 检查隧道状态
check_tunnel() {
    if lsof -i ":${LOCAL_PORT}" -sTCP:LISTEN >/dev/null 2>&1; then
        return 0
    else
        return 1
    fi
}

# 检查节点状态
check_node() {
    local pid_file="${PID_DIR}/node.pid"
    if [[ -f "${pid_file}" ]]; then
        local pid=$(cat "${pid_file}")
        if ps -p "${pid}" >/dev/null 2>&1; then
            return 0
        fi
    fi
    return 1
}

# 启动 SSH 隧道
start_tunnel() {
    if check_tunnel; then
        log_warning "SSH 隧道已在运行 (端口 ${LOCAL_PORT})"
        return 0
    fi

    log_info "启动 SSH 隧道: ${GATEWAY_HOST}:${GATEWAY_PORT} -> 127.0.0.1:${LOCAL_PORT}"

    local tunnel_log="${LOG_DIR}/tunnel.log"
    local pid_file="${PID_DIR}/tunnel.pid"

    # 启动 SSH 隧道（后台运行）
    ssh -f -N -L "${LOCAL_PORT}:127.0.0.1:${GATEWAY_PORT}" \
        "${SSH_USER}@${GATEWAY_HOST}" \
        -o ServerAliveInterval=60 \
        -o ServerAliveCountMax=3 \
        -o ExitOnForwardFailure=yes \
        >> "${tunnel_log}" 2>&1

    # 获取 SSH 进程 PID
    sleep 1
    local ssh_pid=$(lsof -i ":${LOCAL_PORT}" -sTCP:LISTEN -t 2>/dev/null | head -1)

    if [[ -n "${ssh_pid}" ]]; then
        echo "${ssh_pid}" > "${pid_file}"
        log_success "SSH 隧道已启动 (PID: ${ssh_pid})"
    else
        log_error "SSH 隧道启动失败，请检查日志: ${tunnel_log}"
        return 1
    fi
}

# 停止 SSH 隧道
stop_tunnel() {
    local pid_file="${PID_DIR}/tunnel.pid"

    if [[ -f "${pid_file}" ]]; then
        local pid=$(cat "${pid_file}")
        if ps -p "${pid}" >/dev/null 2>&1; then
            log_info "停止 SSH 隧道 (PID: ${pid})"
            kill "${pid}"
            rm -f "${pid_file}"
            log_success "SSH 隧道已停止"
        else
            log_warning "SSH 隧道进程不存在"
            rm -f "${pid_file}"
        fi
    else
        # 尝试通过端口查找进程
        local ssh_pid=$(lsof -i ":${LOCAL_PORT}" -sTCP:LISTEN -t 2>/dev/null | head -1)
        if [[ -n "${ssh_pid}" ]]; then
            log_info "停止 SSH 隧道 (PID: ${ssh_pid})"
            kill "${ssh_pid}"
            log_success "SSH 隧道已停止"
        else
            log_warning "未找到运行中的 SSH 隧道"
        fi
    fi
}

# 启动节点
start_node() {
    if check_node; then
        log_warning "OpenClaw 节点已在运行"
        return 0
    fi

    if ! check_tunnel; then
        log_error "SSH 隧道未运行，请先启动隧道"
        return 1
    fi

    log_info "启动 OpenClaw 节点: ${NODE_NAME}"

    local node_log="${LOG_DIR}/node.log"
    local pid_file="${PID_DIR}/node.pid"

    # 设置环境变量并启动节点（先切换到主目录避免 getcwd 错误）
    export OPENCLAW_GATEWAY_TOKEN="${GATEWAY_TOKEN}"

    cd ~ && nohup openclaw node run \
        --host 127.0.0.1 \
        --port "${LOCAL_PORT}" \
        --display-name "${NODE_NAME}" \
        >> "${node_log}" 2>&1 &

    local node_pid=$!
    echo "${node_pid}" > "${pid_file}"

    sleep 2

    if ps -p "${node_pid}" >/dev/null 2>&1; then
        log_success "OpenClaw 节点已启动 (PID: ${node_pid})"
    else
        log_error "节点启动失败，请检查日志: ${node_log}"
        rm -f "${pid_file}"
        return 1
    fi
}

# 停止节点
stop_node() {
    local pid_file="${PID_DIR}/node.pid"

    if [[ -f "${pid_file}" ]]; then
        local pid=$(cat "${pid_file}")
        if ps -p "${pid}" >/dev/null 2>&1; then
            log_info "停止 OpenClaw 节点 (PID: ${pid})"
            kill "${pid}"
            rm -f "${pid_file}"
            log_success "OpenClaw 节点已停止"
        else
            log_warning "节点进程不存在"
            rm -f "${pid_file}"
        fi
    else
        log_warning "未找到运行中的节点"
    fi
}

# 显示状态
show_status() {
    echo ""
    log_info "OpenClaw 节点隧道状态"
    echo ""

    echo "配置信息:"
    echo "  Gateway: ${GATEWAY_HOST}:${GATEWAY_PORT}"
    echo "  本地端口: ${LOCAL_PORT}"
    echo "  节点名称: ${NODE_NAME}"
    echo ""

    echo "运行状态:"
    if check_tunnel; then
        local ssh_pid=$(lsof -i ":${LOCAL_PORT}" -sTCP:LISTEN -t 2>/dev/null | head -1)
        echo -e "  SSH 隧道: ${GREEN}运行中${NC} (PID: ${ssh_pid})"
    else
        echo -e "  SSH 隧道: ${RED}未运行${NC}"
    fi

    if check_node; then
        local node_pid=$(cat "${PID_DIR}/node.pid" 2>/dev/null || echo "unknown")
        echo -e "  OpenClaw 节点: ${GREEN}运行中${NC} (PID: ${node_pid})"
    else
        echo -e "  OpenClaw 节点: ${RED}未运行${NC}"
    fi

    echo ""
}

# 运行诊断检查
run_diagnose() {
    log_info "运行 OpenClaw 节点隧道诊断检查"
    echo ""
    
    local has_error=0
    local has_warning=0
    
    # 1. 检查 openclaw 命令
    echo "1. 检查 OpenClaw CLI..."
    if command -v openclaw >/dev/null 2>&1; then
        local version=$(openclaw --version 2>/dev/null | head -1 || echo "unknown")
        log_success "OpenClaw CLI 已安装 (${version})"
    else
        log_error "未找到 OpenClaw CLI，请先安装 openclaw"
        has_error=1
    fi
    echo ""
    
    # 2. 检查本地节点配置
    echo "2. 检查本地节点配置..."
    local node_config="${HOME}/.openclaw/openclaw.json"
    if [[ -f "$node_config" ]]; then
        local mode=$(jq -r '.gateway.mode // empty' "$node_config" 2>/dev/null || echo "")
        local url=$(jq -r '.gateway.remote.url // empty' "$node_config" 2>/dev/null || echo "")
        
        if [[ "$mode" == "remote" ]]; then
            log_success "节点模式正确: remote"
        else
            log_warning "节点模式为 '${mode}'，建议设为 'remote' 以通过隧道连接"
            has_warning=1
        fi
        
        if [[ "$url" == *":${LOCAL_PORT}"* ]]; then
            log_success "节点 URL 与隧道端口匹配: ${url}"
        else
            log_warning "节点 URL (${url}) 与隧道端口 (${LOCAL_PORT}) 不匹配"
            log_info "  建议检查: ~/.openclaw/openclaw.json"
            has_warning=1
        fi
    else
        log_warning "未找到节点配置文件: ${node_config}"
        has_warning=1
    fi
    echo ""
    
    # 3. 检查 SSH 隧道
    echo "3. 检查 SSH 隧道..."
    if check_tunnel; then
        local ssh_pid=$(lsof -i ":${LOCAL_PORT}" -sTCP:LISTEN -t 2>/dev/null | head -1)
        log_success "SSH 隧道运行正常 (PID: ${ssh_pid}, 端口: ${LOCAL_PORT})"
        
        # 测试端口连接
        if nc -z 127.0.0.1 "${LOCAL_PORT}" 2>/dev/null; then
            log_success "本地端口 ${LOCAL_PORT} 可连接"
        else
            log_warning "本地端口 ${LOCAL_PORT} 连接测试失败"
            has_warning=1
        fi
    else
        log_error "SSH 隧道未运行"
        log_info "  请运行: openclaw-tunnel start-tunnel"
        has_error=1
    fi
    echo ""
    
    # 4. 检查节点进程
    echo "4. 检查节点进程..."
    if check_node; then
        local node_pid=$(cat "${PID_DIR}/node.pid" 2>/dev/null || echo "unknown")
        log_success "节点进程运行中 (PID: ${node_pid})"
        
        # 尝试获取节点状态
        if command -v openclaw >/dev/null 2>&1; then
            # 通过实际功能测试确认节点是否可用
            local node_caps=$(openclaw nodes status 2>/dev/null | grep -E "${NODE_NAME}" | grep "connected" | head -1 | awk '{print $NF}')
            if [[ -n "$node_caps" ]]; then
                log_success "节点已连接到 Gateway (能力: ${node_caps})"
            else
                log_warning "节点未显示为 connected 状态"
                log_info "  可能原因: 名称不匹配、Token 错误，或节点正在连接中"
                has_warning=1
            fi
        fi
    else
        log_error "节点进程未运行"
        log_info "  请运行: openclaw-tunnel start-node"
        has_error=1
    fi
    echo ""
    
    # 5. 功能测试（实际测试节点是否可用）
    echo "5. 功能测试..."
    if command -v openclaw >/dev/null 2>&1; then
        # 尝试通过 Gateway 访问节点状态
        local node_test=$(openclaw nodes describe "${NODE_NAME}" 2>&1 | head -1)
        if [[ -n "$node_test" ]]; then
            log_success "功能测试通过: 可以通过 Gateway 访问节点"
        else
            log_warning "功能测试: 无法通过 Gateway 访问节点详情"
        fi
    fi
    echo ""
    
    # 6. Gateway 常见配置问题检查
    echo "6. Gateway 配置检查 (常见问题)..."
    echo ""
    log_info "请检查 Gateway 服务器 (${GATEWAY_HOST}) 的以下配置:"
    echo ""
    echo "  📋 server.listen 设置:"
    echo "     ✓ 推荐: 'loopback' (127.0.0.1)"
    echo "     ⚠ 注意: 如果设为 'lan' 或 'tailnet'，SSH 隧道可能无法正常工作"
    echo "     📖 配置路径: ~/.openclaw/openclaw.json"
    echo ""
    echo "  🔐 auth.mode 设置:"
    echo "     ✓ 推荐: 'token'"
    echo "     ✗ 不推荐: 'password' (安全性较低)"
    echo "     📖 确保 Token 与本机配置一致"
    echo ""
    echo "  🌐 防火墙设置:"
    echo "     ✓ 确保端口 ${GATEWAY_PORT} 在 Gateway 服务器上开放"
    echo "     ✓ 如果 Gateway 在云端，检查安全组规则"
    echo ""
    
    # 7. 给出建议
    echo "7. 诊断建议..."
    echo ""
    if [[ $has_error -gt 0 ]]; then
        log_error "发现错误，请先修复上述问题"
        log_info "修复后运行: openclaw-tunnel restart"
    elif [[ $has_warning -gt 0 ]]; then
        log_warning "发现警告，服务可能可以运行但配置不够优化"
        log_info "建议根据警告信息调整配置"
    else
        log_success "所有检查通过！配置看起来正常。"
        log_info "如果仍有问题，请检查 Gateway 端配置或查看日志:"
        log_info "  openclaw-tunnel logs all"
    fi
    echo ""
    
    return $has_error
}

# 启动所有服务
start_all() {
    log_info "启动 OpenClaw 节点隧道服务"
    start_tunnel
    sleep 2
    start_node
    echo ""
    show_status
    
    # 自动运行诊断（用于开机自启时发现问题）
    echo ""
    log_info "正在运行自动诊断..."
    if ! run_diagnose; then
        log_warning "诊断发现问题，请查看上方详细信息"
        log_info "查看日志: openclaw-tunnel logs all"
    fi
}

# 停止所有服务
stop_all() {
    log_info "停止 OpenClaw 节点隧道服务"
    stop_node
    sleep 1
    stop_tunnel
    echo ""
    show_status
}

# 重启所有服务
restart_all() {
    log_info "重启 OpenClaw 节点隧道服务"
    stop_all
    sleep 2
    start_all
}

# 查看日志
show_logs() {
    local log_type="${1:-all}"

    case "${log_type}" in
        tunnel)
            tail -f "${LOG_DIR}/tunnel.log"
            ;;
        node)
            tail -f "${LOG_DIR}/node.log"
            ;;
        all|*)
            tail -f "${LOG_DIR}/tunnel.log" "${LOG_DIR}/node.log"
            ;;
    esac
}

# 安装开机自启
install_autostart() {
    local plist_file="${HOME}/Library/LaunchAgents/ai.openclaw.tunnel.plist"
    local script_path="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/$(basename "${BASH_SOURCE[0]}")"

    log_info "安装开机自启动服务"

    cat > "${plist_file}" <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>ai.openclaw.tunnel</string>
    <key>ProgramArguments</key>
    <array>
        <string>${script_path}</string>
        <string>start</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <dict>
        <key>SuccessfulExit</key>
        <false/>
    </dict>
    <key>StandardOutPath</key>
    <string>${LOG_DIR}/launchd.log</string>
    <key>StandardErrorPath</key>
    <string>${LOG_DIR}/launchd-error.log</string>
</dict>
</plist>
EOF

    launchctl load "${plist_file}"
    log_success "开机自启动已安装: ${plist_file}"
    log_info "服务将在下次开机时自动启动"
}

# 卸载开机自启
uninstall_autostart() {
    local plist_file="${HOME}/Library/LaunchAgents/ai.openclaw.tunnel.plist"

    if [[ -f "${plist_file}" ]]; then
        log_info "卸载开机自启动服务"
        launchctl unload "${plist_file}" 2>/dev/null || true
        rm -f "${plist_file}"
        log_success "开机自启动已卸载"
    else
        log_warning "未找到开机自启动配置"
    fi
}

# 显示帮助
show_help() {
    cat <<EOF
OpenClaw 节点隧道管理工具

用法: openclaw-tunnel <命令> [选项]

命令:
  config              交互式配置
  start               启动隧道和节点 (自动运行诊断)
  stop                停止隧道和节点
  restart             重启隧道和节点
  status              显示运行状态
  diagnose            运行诊断检查 (检查配置常见问题)
  logs [type]         查看日志 (tunnel|node|all)

  start-tunnel        仅启动 SSH 隧道
  stop-tunnel         仅停止 SSH 隧道
  start-node          仅启动节点
  stop-node           仅停止节点

  install-autostart   安装开机自启动
  uninstall-autostart 卸载开机自启动

  help                显示此帮助信息

示例:
  openclaw-tunnel config          # 配置隧道参数
  openclaw-tunnel start           # 启动服务并自动诊断
  openclaw-tunnel status          # 查看状态
  openclaw-tunnel diagnose        # 手动运行诊断检查
  openclaw-tunnel logs node       # 查看节点日志
  openclaw-tunnel install-autostart  # 安装开机自启

配置文件: ${CONFIG_FILE}
日志目录: ${LOG_DIR}
EOF
}

# 主函数
main() {
    # 切换到用户主目录，避免 getcwd 错误（如果当前目录被删除）
    cd ~ || cd / || true
    
    init_dirs
    load_config

    local command="${1:-help}"

    case "${command}" in
        config)
            interactive_config
            ;;
        start)
            start_all
            ;;
        stop)
            stop_all
            ;;
        restart)
            restart_all
            ;;
        status)
            show_status
            ;;
        diagnose)
            run_diagnose
            ;;
        logs)
            show_logs "${2:-all}"
            ;;
        start-tunnel)
            start_tunnel
            ;;
        stop-tunnel)
            stop_tunnel
            ;;
        start-node)
            start_node
            ;;
        stop-node)
            stop_node
            ;;
        install-autostart)
            install_autostart
            ;;
        uninstall-autostart)
            uninstall_autostart
            ;;
        help|--help|-h)
            show_help
            ;;
        *)
            log_error "未知命令: ${command}"
            echo ""
            show_help
            exit 1
            ;;
    esac
}

main "$@"
