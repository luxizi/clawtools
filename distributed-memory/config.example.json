{
  "$schema": "./config.schema.json",
  "dbPath": "./data/memory.lancedb",
  "llmClassification": {
    "provider": "ollama",
    "apiKey": "",
    "baseURL": "http://localhost:11434/v1",
    "model": "qwen3.5:2b"
  },
  "embedding": {
    "provider": "local",
    "model": "all-MiniLM-L6-v2",
    "dimensions": 384
  },
  "noiseFilter": {
    "enabled": true,
    "keywords": [
      "测试",
      "test",
      "ignore",
      "debug"
    ],
    "minLength": 5,
    "maxLength": 10000
  },
  "dedup": {
    "enabled": true,
    "threshold": 1.0,
    "checkLastN": 100
  },
  "retrieval": {
    "topK": 5,
    "minScore": 0.7
  }
}
